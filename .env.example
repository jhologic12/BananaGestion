# Database
# Get from Supabase: Settings → Database → Connection string (URI format)
# ConnectionStrings__DefaultConnection=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# JWT (generate with: openssl rand -base64 64)
# Jwt__Key=

# JWT Settings
Jwt__Issuer=BananaGestion
Jwt__Audience=BananaGestionApp
Jwt__ExpireMinutes=60

# CORS (your production frontend URL)
# AllowedOrigins__0=https://bananagestion.vercel.app

# Environment
ASPNETCORE_ENVIRONMENT=Production
